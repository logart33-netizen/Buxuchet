<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>1С | Экосистема для бизнеса</title>
    <!-- Используем шрифт Inter для строгого и чистого вида, как у Контура -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #19191a;
            --border-color: #333333;
            --text-main: #ffffff;
            --text-muted: #8c8c8c;
            /* Цвета при наведении */
            --hover-yellow: #f2ce00;
            --hover-teal: #11c09e;
            --hover-purple: #818cf8;
            --hover-blue: #3b82f6;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        /* НАВИГАЦИЯ */
        .navbar {
            display: flex;
            align-items: center;
            padding: 0 48px;
            height: 80px;
            border-bottom: 1px solid var(--border-color);
        }
        .logo {
            font-size: 24px;
            font-weight: 700;
            margin-right: 64px;
            letter-spacing: -0.5px;
        }
        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }
        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-links a:hover {
            color: var(--text-main);
        }
        .nav-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .btn-login {
            border: 1px solid rgba(255, 255, 255, 0.3);
            background: transparent;
            color: white;
            padding: 10px 24px;
            border-radius: 40px;
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: 0.2s;
        }
        .btn-login:hover {
            border-color: white;
            background: rgba(255, 255, 255, 0.05);
        }
        /* ОСНОВНАЯ СЕТКА (HERO) */
        .hero {
            display: flex;
            flex: 1;
        }
        .hero-left {
            width: 40%;
            padding: 64px 48px;
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }
        .hero-left h1 {
            font-size: 56px;
            line-height: 1.1;
            font-weight: 700;
            margin-bottom: 24px;
            letter-spacing: -1.5px;
        }
        .hero-left p {
            color: var(--text-muted);
            font-size: 18px;
            line-height: 1.5;
            max-width: 90%;
        }
        .hero-right {
            width: 60%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            grid-auto-rows: minmax(350px, 1fr);
        }
        /* КАРТОЧКА (BENTO CELL) */
        .bento-cell-wrapper {
            position: relative;
            border-right: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            text-decoration: none;
            color: var(--text-main);
        }
        .bento-cell-wrapper:nth-child(even) {
            border-right: none;
        }
        .bento-cell-wrapper.wide {
            grid-column: span 2;
            border-right: none;
        }
        /* Внутренний контейнер, который анимируется */
        .bento-cell {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            padding: 40px;
            background-color: transparent;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            z-index: 1;
        }
        .bento-title {
            font-size: 32px;
            font-weight: 600;
            line-height: 1.15;
            margin-bottom: 16px;
            letter-spacing: -0.5px;
            z-index: 3;
            transition: color 0.3s;
            max-width: 80%;
        }
        /* Декоративные элементы в карточке (цифры, SVG) */
        .bento-deco {
            position: absolute;
            z-index: 2;
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .bento-deco.numbers {
            font-size: 140px;
            font-weight: 800;
            color: rgba(0, 0, 0, 0.08);
            /* Полупрозрачный черный для желтого фона */
            top: -20px;
            right: 10px;
            transform: translateY(20px);
            letter-spacing: -8px;
        }
        .bento-deco.icon svg {
            width: 140px;
            height: 140px;
            stroke: rgba(255, 255, 255, 0.8);
        }
        .bento-deco.icon {
            top: 20px;
            right: 20px;
            transform: scale(0.8) rotate(-20deg);
        }
        /* Анимация вращения SVG */
        @keyframes spinSlow {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }
        /* Тэги (появляются снизу при наведении) */
        .bento-tags {
            margin-top: auto;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            opacity: 0;
            transform: translateY(15px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 3;
        }
        .tag {
            border: 1px solid rgba(255, 255, 255, 0.4);
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 500;
            white-space: nowrap;
            transition: border-color 0.3s, color 0.3s;
        }
        /* ==================================
           ЭФФЕКТЫ НАВЕДЕНИЯ
           ================================== */
        /* 1С Бухгалтерия (Yellow) */
        .bento-cell-wrapper:hover .bento-cell.hover-yellow {
            background-color: var(--hover-yellow);
            border-radius: 16px;
            /* Скругление как у Контура */
            z-index: 10;
        }
        .bento-cell-wrapper:hover .bento-cell.hover-yellow .bento-title {
            color: #000000;
        }
        .bento-cell-wrapper:hover .bento-cell.hover-yellow .tag {
            border-color: rgba(0, 0, 0, 0.2);
            color: #000000;
        }
        .bento-cell-wrapper:hover .bento-cell.hover-yellow .bento-tags {
            opacity: 1;
            transform: translateY(0);
        }
        .bento-cell-wrapper:hover .bento-cell.hover-yellow .bento-deco {
            opacity: 1;
            transform: translateY(0);
        }
        /* ИТС (Teal) */
        .bento-cell-wrapper:hover .bento-cell.hover-teal {
            background-color: var(--hover-teal);
            border-radius: 16px;
            z-index: 10;
        }
        .bento-cell-wrapper:hover .bento-cell.hover-teal .bento-tags {
            opacity: 1;
            transform: translateY(0);
        }
        .bento-cell-wrapper:hover .bento-cell.hover-teal .bento-deco {
            opacity: 1;
            transform: scale(1) rotate(0);
        }
        .bento-cell-wrapper:hover .bento-cell.hover-teal .bento-deco.icon svg {
            animation: spinSlow 8s linear infinite;
        }
        /* Внедрение (Purple) */
        .bento-cell-wrapper:hover .bento-cell.hover-purple {
            background-color: var(--hover-purple);
            border-radius: 16px;
            z-index: 10;
        }
        .bento-cell-wrapper:hover .bento-cell.hover-purple .bento-tags {
            opacity: 1;
            transform: translateY(0);
        }
        .bento-cell-wrapper:hover .bento-cell.hover-purple .bento-deco {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        /* Прочие решения (White Button) */
        .card-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: white;
            color: black;
            padding: 24px 32px;
            border-radius: 16px;
            font-size: 24px;
            font-weight: 600;
            position: absolute;
            bottom: 40px;
            left: 40px;
            right: 40px;
            transition: transform 0.2s;
        }
        .card-link:hover {
            transform: scale(1.02);
        }
        /* ПОДВАЛ (Логотипы продуктов) */
        .footer-bar {
            padding: 32px 48px;
            border-top: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 32px;
        }
        .product-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-main);
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
        }
        .icon-box {
            width: 24px;
            height: 24px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            font-weight: bold;
        }
        /* Адаптивность */
        @media (max-width: 1024px) {
            .hero {
                flex-direction: column;
            }
            .hero-left {
                width: 100%;
                border-right: none;
                border-bottom: 1px solid var(--border-color);
            }
            .hero-right {
                width: 100%;
            }
        }
        @media (max-width: 768px) {
            .nav-links {
                display: none;
            }
            .hero-right {
                grid-template-columns: 1fr;
            }
            .bento-cell-wrapper {
                border-right: none;
            }
            .bento-cell-wrapper.wide {
                grid-column: span 1;
            }
            .hero-left h1 {
                font-size: 40px;
            }
        }
    </style>
</head>
<body>
    <!-- НАВИГАЦИЯ -->
    <nav class="navbar">
        <div class="logo">1С</div>
        <ul class="nav-links">
            <li><a href="#">Продукты и решения</a></li>
            <li><a href="#">Кейсы</a></li>
            <li><a href="#">Поддержка</a></li>
        </ul>
        <div class="nav-right">
            <a href="#" class="btn-login">Оставить заявку</a>
        </div>
    </nav>
    <!-- ОСНОВНАЯ ЧАСТЬ -->
    <section class="hero">
        <!-- Левая часть -->
        <div class="hero-left">
            <h1>Экосистема<br>для бизнеса</h1>
            <p>Автоматизация бухгалтерии, документооборота, зарплаты, торговых процессов и аналитики в одной платформе
            </p>
        </div>
        <!-- Правая часть (Сетка) -->
        <div class="hero-right">
            <!-- КАРТОЧКА 1: 1С БУХГАЛТЕРИЯ -->
            <a href="#" class="bento-cell-wrapper">
                <div class="bento-cell hover-yellow">
                    <h3 class="bento-title">1С:Бухгалтерия</h3>
                    <!-- Тени цифр при наведении -->
                    <div class="bento-deco numbers">8.3</div>
                    <div class="bento-tags">
                        <span class="tag">Налоговый учет</span>
                        <span class="tag">Отчетность</span>
                        <span class="tag">Зарплата</span>
                    </div>
                </div>
            </a>
            <!-- КАРТОЧКА 2: ИТС (ЭДО и сервисы) -->
            <a href="#" class="bento-cell-wrapper">
                <div class="bento-cell hover-teal">
                    <h3 class="bento-title">ИТС и Сервисы<br>поддержки</h3>
                    <!-- Круглые анимированные стрелки -->
                    <div class="bento-deco icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M21 12A9 9 0 0 0 6 5.3L3.5 3M3 12a9 9 0 0 0 15 6.7l2.5 2.2" stroke-linecap="round"
                                stroke-linejoin="round" />
                            <path d="M6 3v4h4M18 21v-4h-4" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    <div class="bento-tags">
                        <span class="tag">1С-Отчетность</span>
                        <span class="tag">ЭДО</span>
                        <span class="tag">Обновления</span>
                    </div>
                </div>
            </a>
            <!-- КАРТОЧКА 3: ВНЕДРЕНИЕ -->
            <a href="#" class="bento-cell-wrapper">
                <div class="bento-cell hover-purple">
                    <h3 class="bento-title">Внедрение и<br>разработка</h3>
                    <!-- Иконка кода / интеграции -->
                    <div class="bento-deco icon" style="top: 30px; right: 30px; transform: scale(1);">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="16 18 22 12 16 6"></polyline>
                            <polyline points="8 6 2 12 8 18"></polyline>
                        </svg>
                    </div>
                    <div class="bento-tags">
                        <span class="tag">Аудит процессов</span>
                        <span class="tag">Доработка кода</span>
                        <span class="tag">API Интеграции</span>
                    </div>
                </div>
            </a>
            <!-- КАРТОЧКА 4: ВСЕ РЕШЕНИЯ -->
            <a href="#" class="bento-cell-wrapper">
                <div class="bento-cell" style="position: relative;">
                    <!-- Белая плашка-кнопка как в Контуре -->
                    <div class="card-link">
                        Все решения
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="7" y1="17" x2="17" y2="7"></line>
                            <polyline points="7 7 17 7 17 17"></polyline>
                        </svg>
                    </div>
                </div>
            </a>
        </div>
    </section>
    <!-- ПОДВАЛ (Как в Контуре логотипы продуктов) -->
    <footer class="footer-bar">
        <a href="#" class="product-logo">
            <div class="icon-box" style="background: #f2ce00; color: black;">Б</div> Бухгалтерия
        </a>
        <a href="#" class="product-logo">
            <div class="icon-box" style="background: #11c09e;">Э</div> ЭДО
        </a>
        <a href="#" class="product-logo">
            <div class="icon-box" style="background: #818cf8;">З</div> Зарплата
        </a>
        <a href="#" class="product-logo">
            <div class="icon-box" style="background: #ef4444;">Р</div> Розница
        </a>
        <a href="#"
            style="margin-left: auto; color: var(--text-muted); text-decoration: none; font-size: 14px; font-weight: 500;">
            ... Ещё
        </a>
    </footer>
</body>
</html>
